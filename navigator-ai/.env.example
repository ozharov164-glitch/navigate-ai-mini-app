# =============================================================================
# НавигаторAI (@NavigAI_bot) — переменные окружения
# Скопируйте в .env и заполните перед запуском: cp .env.example .env
# =============================================================================

# --- Общие ---
APP_NAME=НавигаторAI
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-random-64-char-string
ENCRYPTION_KEY=change-me-32-byte-base64-fernet-key

# --- Telegram Bot ---
BOT_TOKEN=123456:ABC-DEF...
BOT_USERNAME=NavigAI_bot
WEBHOOK_URL=https://your-domain.com/bot/webhook
WEBHOOK_SECRET=random-webhook-secret-string
MINI_APP_URL=https://ozharov164-glitch.github.io/navigate-ai-mini-app/

# Только личные чаты (группы отклоняются автоматически)
ALLOW_PRIVATE_ONLY=true

# --- PostgreSQL ---
POSTGRES_USER=navigai
POSTGRES_PASSWORD=strong_password_here
POSTGRES_DB=navigai
DATABASE_URL=postgresql+asyncpg://navigai:strong_password_here@postgres:5432/navigai

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# --- Backend API ---
BACKEND_PORT=8000
API_BASE_URL=http://backend:8000
CORS_ORIGINS=https://ozharov164-glitch.github.io,https://web.telegram.org

# --- OpenRouter (DeepSeek V3.2) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=deepseek/deepseek-v3.2
# Экономия баланса (~$30): меньше токенов, дольше кэш, без LLM в вечернем дайджесте
AI_MAX_TOKENS=2048
AI_CACHE_TTL=3600
AI_BUDGET_MODE=true
AI_WORKER_EVENING_LLM=false
AI_JSON_RETRIES=2
AI_JSON_RETRIES_PREMIUM=1
AI_VISION_MAX_TOKENS=800
AI_TRANSCRIBE_MAX_TOKENS=512

# Системный промпт (можно переопределить)
AI_SYSTEM_PROMPT=Ты — НавигаторAI, мощный личный AI-навигатор жизни пользователя. Проанализируй сообщение (транскрипт голоса + описание фото). Верни ТОЛЬКО валидный JSON с ключами: tasks, expenses, routes, reminders, summary, smart_insights. Будь максимально точным и полезным для российского пользователя 2026 года.

# --- Yandex Maps ---
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
YANDEX_GEOCODER_URL=https://geocode-maps.yandex.ru/1.x/
YANDEX_ROUTER_URL=https://api.routing.yandex.net/v2/route
YANDEX_STATIC_MAP_URL=https://static-maps.yandex.ru/1.x/
YANDEX_DAILY_LIMIT=800
YANDEX_STATIC_MAP_ENABLED=true
YANDEX_STATIC_DISABLE_ABOVE=700

# Whisper на VPS (docker compose --profile whisper up)
WHISPER_ENABLED=false
WHISPER_URL=http://whisper:8000
WHISPER_MODEL=small

# Голос и фото только для Premium
PREMIUM_ONLY_MULTIMEDIA=true

# --- Платежи: Telegram Stars ---
STARS_BASIC_PRICE=199
STARS_PREMIUM_PRICE=399
STARS_PROVIDER_TOKEN=

# --- Платежи: YooKassa (Яндекс Пэй) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://ozharov164-glitch.github.io/navigate-ai-mini-app/?page=premium
YOOKASSA_BASIC_PRICE_RUB=199
YOOKASSA_PREMIUM_PRICE_RUB=399

# --- Freemium лимиты ---
FREE_DAILY_ACTIONS=10
PREMIUM_DAILY_ACTIONS=50

# --- Proactive уведомления ---
MORNING_DIGEST_HOUR=8
EVENING_SUMMARY_HOUR=21
DEFAULT_TIMEZONE=Europe/Moscow

# --- Referral ---
REFERRAL_BONUS_DAYS=14

# --- Frontend (Vite build) ---
VITE_API_URL=/api
FRONTEND_PORT=3000

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Загрузки ---
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20
